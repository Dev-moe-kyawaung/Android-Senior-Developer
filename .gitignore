# ============================================
# GitHub Pages Portfolio - .gitignore
# ============================================

# Operating System Files
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor and IDE Files
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Node.js (if you add build tools later)
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Build outputs
# ============================================
dist/
build/
.cache/
*.log

# Temporary files
# ============================================
*.tmp
*.temp
.tmp/
.temp/

# Backup files
# ============================================
*.bak
*.backup
*~

# Local development
# ============================================
.env
.env.local
.env.*.local

# Testing
# ============================================
coverage/
.nyc_output/

# Optional
# ============================================
drafts/
notes.txt
TODO.md
